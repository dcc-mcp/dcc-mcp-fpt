# Copy to .env for local development. Do not commit real credentials.
SHOTGRID_URL=https://example.shotgrid.autodesk.com
SHOTGRID_SCRIPT_NAME=your_script_name
SHOTGRID_SCRIPT_KEY=your_script_key

# Project scoping. Use a project name, code, tank name, or numeric ID.
SHOTGRID_PROJECT=your_project_code
# SHOTGRID_PROJECT_ID=123

# Permission fallback for this local session: read, write, or admin.
SHOTGRID_PERMISSION_LEVEL=read

# Optional allowlist. JSON and CSV are both supported.
# SHOTGRID_PROJECT_PERMISSIONS={"your_project_code":"write","id:123":"read"}

# dcc-mcp gateway integration. Set port to 0 to run standalone only.
DCC_MCP_GATEWAY_PORT=9765
# DCC_MCP_REGISTRY_DIR=C:/Users/you/.dcc-mcp/registry
# DCC_MCP_FPT_GATEWAY_SCENE=project:your_project_code
# DCC_MCP_FPT_GATEWAY_DISPLAY_NAME=FPT your_project_code
DCC_MCP_FPT_ENABLE_GATEWAY_FAILOVER=1

# Custom skill injection. Use ; on Windows and : on Linux/macOS for multiple roots.
# DCC_MCP_FPT_SKILL_PATHS=C:/studio/fpt-skills
# DCC_MCP_SKILL_PATHS=C:/studio/shared-dcc-skills

# Required to run tools/shotgrid_live_crud_smoke.py with mutations.
SHOTGRID_LIVE_CRUD_CONFIRM=0
SHOTGRID_SMOKE_ENTITY_TYPE=Playlist
